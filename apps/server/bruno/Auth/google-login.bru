meta {
  name: Google Login
  type: http
  seq: 5
}

post {
  url: {{base_url}}/auth/google/login
  body: json
  auth: none
}

body:json {
  {
    "id_token": "GOOGLE_ID_TOKEN_FROM_FRONTEND"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("owner_token", res.body.data.access_token);
  }
}
