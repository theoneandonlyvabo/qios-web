meta {
  name: Kasir Login (QR)
  type: http
  seq: 8
}

post {
  url: {{base_url}}/kasir/auth/login/qr
  body: json
  auth: none
}

body:json {
  {
    "qr_token": "QR_TOKEN_FROM_REGENERATE_QR"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("operator_token", res.body.data.access_token);
  }
}
