meta {
  name: Kasir Login (Credentials)
  type: http
  seq: 7
}

post {
  url: {{base_url}}/kasir/auth/login
  body: json
  auth: none
}

body:json {
  {
    "operator_code": "kasir01",
    "password": "kasir123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("operator_token", res.body.data.access_token);
  }
}
