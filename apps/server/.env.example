DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=qios

JWT_SECRET=your-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# 64 hex chars (= 32 bytes). Generate via: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key-here

# Comma-separated frontend origins. Dev: all localhost ports. Prod: actual domain(s).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Cookie flags for the httpOnly refresh-token cookie.
# Dev (HTTP localhost): Secure=false, SameSite=lax
# Prod (FE/BE share parent domain, e.g. app.example.com + api.example.com):
#   COOKIE_SECURE=true, COOKIE_SAMESITE=lax, COOKIE_DOMAIN=.example.com
# Prod (cross-site, different registrable domains):
#   COOKIE_SECURE=true, COOKIE_SAMESITE=none — requires CSRF protection
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
