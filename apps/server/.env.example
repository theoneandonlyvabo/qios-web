DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=qios

JWT_SECRET=your-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

XENDIT_SECRET_KEY=xnd_development_xxx
XENDIT_ENV=sandbox
XENDIT_BASE_URL=https://api.xendit.co
XENDIT_WEBHOOK_TOKEN=your-xendit-webhook-token
XENDIT_PLATFORM_ACCOUNT_ID=your-xendit-platform-account-id
# Wajib pakai public URL (ngrok untuk dev) supaya Xendit bisa kirim webhook ke local.
# Kosongin kalau pakai global webhook yang dikonfigurasi di Xendit dashboard.
XENDIT_CALLBACK_URL=https://your-ngrok-url.ngrok-free.dev/webhooks/xendit

# 64 hex chars (= 32 bytes). Generate via: openssl rand -hex 32
ENCRYPTION_KEY=your-64-hex-char-encryption-key
