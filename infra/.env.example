# Copy to infra/.env and fill in values before running docker compose

# Application
APP_PORT=8080

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=qios

# JWT (required — no defaults)
JWT_SECRET=your-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h
