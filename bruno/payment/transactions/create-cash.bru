meta {
  name: Create Cash Transaction
  type: http
  seq: 5
}

post {
  url: {{base_url}}/transactions
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{operator_token}}
}

body:json {
  {
    // Replace product_id with a real UUID from POST /products
    "payment_method": "CASH",
    "items": [
      {
        "product_id": "74ca8741-3a90-4ef9-bbcb-c2bb68187f7d",
        "quantity": 2
      }
    ],
    "note": "Test cash order"
  }
}
